<Window x:Class="EdilPaintPreventibiviGen.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:EdilPaintPreventibiviGen.Models"
        xmlns:converters="clr-namespace:EdilPaintPreventibiviGen.Converters"
        mc:Ignorable="d"
        RenderOptions.BitmapScalingMode="HighQuality"
        Icon="pack://application:,,,/Assets/Windowsicon/storico.png"
        Title="Storico Preventivi"
        Width="1220"
        Height="760"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:SyncStatusToColorConverter x:Key="SyncStatusToColorConverter"/>
        <converters:SyncStatusToTooltipConverter x:Key="SyncStatusToTooltipConverter"/>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
        </Style>

        <Style x:Key="HistoryIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FFF3F4F6"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FF1F2937"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFE5E7EB"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFD1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryPdfButtonStyle" TargetType="Button" BasedOn="{StaticResource HistoryIconButtonStyle}">
            <Setter Property="Background" Value="#FFFEE2E2"/>
            <Setter Property="BorderBrush" Value="#FFFCA5A5"/>
            <Setter Property="Foreground" Value="#FFB91C1C"/>
        </Style>

        <Style x:Key="HistoryDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource HistoryIconButtonStyle}">
            <Setter Property="Background" Value="#FFFEE2E2"/>
            <Setter Property="BorderBrush" Value="#FFFECACA"/>
            <Setter Property="Foreground" Value="{StaticResource DangerRedBrush}"/>
        </Style>

        <Style x:Key="ModernHistoryGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9DEE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F6"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="48"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F6F8FA"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Finalizzato">
                    <Setter Property="Background" Value="{StaticResource StatusFinalizzatoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Finalizzato"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Spedito">
                    <Setter Property="Background" Value="{StaticResource StatusSpeditoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Spedito"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource WarningYellowBrush}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Confermato">
                    <Setter Property="Background" Value="{StaticResource StatusConfermatoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Confermato"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource PurpleBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Finito">
                    <Setter Property="Background" Value="{StaticResource StatusFinitoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Finito"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource SuccessGreenBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Rifiutato">
                    <Setter Property="Background" Value="{StaticResource StatusRifiutatoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Rifiutato"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource DangerRedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent" Margin="18">
        <Border Background="{StaticResource RowBackgroundBrush}"
                CornerRadius="16"
                BorderBrush="#22000000"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  ShadowDepth="0"
                                  Opacity="0.22"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0"
                      Margin="18,0,10,0"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Storico preventivi"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>
                        <TextBlock Text="Consulta, filtra e gestisci i preventivi già generati"
                                   Margin="0,2,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource HeaderButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Chiudi"
                            Content="✕"/>
                </Grid>

                <!-- DIVIDER -->
                <Border Grid.Row="1" Background="#18000000"/>

                <!-- FILTERS -->
                <Border Grid.Row="2"
                        Margin="22,20,22,14"
                        Background="#F6F8FA"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="#12000000"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Cerca per cliente, numero o riferimento"/>

                            <TextBox x:Name="TxtSearchHistory"
                                     Grid.Row="2"
                                     KeyDown="OnSearchKeyDown"/>
                            
                            <Button Grid.Column="1"
                                        Content="🔍"
                                        Width="38"
                                        Height="38"
                                        Margin="8,0,0,0"
                                        FontSize="16"
                                        Cursor="Hand"
                                        Background="{StaticResource PrimaryBlueBrush}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Click="OnSearchButtonClick"
                                        ToolTip="Cerca (Invio)">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1565C0"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0D47A1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Stato"/>

                            <ComboBox x:Name="CboFilterStatus"
                                      Grid.Row="2"
                                      SelectionChanged="OnFilterChanged">
                                <ComboBoxItem Content="Tutti" IsSelected="True"/>
                                <ComboBoxItem Content="Finalizzato"/>
                                <ComboBoxItem Content="Spedito"/>
                                <ComboBoxItem Content="Confermato"/>
                                <ComboBoxItem Content="Finito"/>
                                <ComboBoxItem Content="Rifiutato"/>
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Column="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Dal"/>

                            <DatePicker x:Name="DpStart"
                                        Grid.Row="2"
                                        SelectedDateChanged="OnFilterChanged"/>
                        </Grid>

                        <Grid Grid.Column="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Al"/>

                            <DatePicker x:Name="DpEnd"
                                        Grid.Row="2"
                                        SelectedDateChanged="OnFilterChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- TABLE -->
                <Border Grid.Row="3"
                        Margin="22,0,22,18"
                        Background="White"
                        BorderBrush="#D9DEE5"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="0">
                    <Grid>
                        <DataGrid x:Name="GridHistory"
                                  ItemsSource="{Binding HistoryView}"
                                  Style="{StaticResource ModernHistoryGridStyle}"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Item">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="12" Height="12" 
                                                 Fill="{Binding SyncStatus, Converter={StaticResource SyncStatusToColorConverter}}"
                                                 ToolTip="{Binding SyncStatus, Converter={StaticResource SyncStatusToTooltipConverter}}"
                                                 Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="148" Header="Azioni">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="🔄"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnCopyPastQuoteClick"
                                                    ToolTip="Copia in un nuovo preventivo"/>
                                            <Button Content="✏️"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnEditPastQuoteClick"
                                                    ToolTip="Modifica e aggiorna questo preventivo"/>
                                            <Button Content="📁"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnOpenCustomerFolderClick"
                                                    ToolTip="Apri cartella cliente"/>
                                            <Button Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnNotesClick"
                                                    ToolTip="Apri appunti interni"
                                                    Width="30" Height="30"
                                                    Content="{Binding}">
                                                <Button.ContentTemplate>
                                                    <DataTemplate DataType="{x:Type models:QuoteHistorySummary}">
                                                        <Grid Width="20" Height="20">
                                                            <TextBlock Text="📝"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="14"/>
                                                            <Ellipse Width="9" Height="9"
                                                                     Fill="Red"
                                                                     HorizontalAlignment="Right"
                                                                     VerticalAlignment="Top"
                                                                     Margin="0,-2,-2,0">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasNotes}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </Grid>
                                                    </DataTemplate>
                                                </Button.ContentTemplate>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Data"
                                                Binding="{Binding Date, StringFormat=dd/MM/yyyy}"
                                                IsReadOnly="True"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="N. Prev"
                                                Binding="{Binding QuoteNumber}"
                                                IsReadOnly="True"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Cliente"
                                                Binding="{Binding CustomerName}"
                                                IsReadOnly="True"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding CustomerName}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Riferimento"
                                                Binding="{Binding ReferenceName}"
                                                IsReadOnly="True"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding ReferenceName}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Totale (€)"
                                                Binding="{Binding Total, StringFormat={}{0:N2}}"
                                                IsReadOnly="True"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Stato" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.StatusOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Status, Mode=TwoWay}"
                                                  SelectionChanged="OnStatusChanged"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="" Width="54">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🔍"
                                                Style="{StaticResource HistoryPdfButtonStyle}"
                                                Click="OnOpenPastQuotePdfClick"
                                                ToolTip="Apri il PDF, oppure la cartella se il file non esiste"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="" Width="54">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️"
                                                Style="{StaticResource HistoryDeleteButtonStyle}"
                                                Click="OnDeletePastQuoteClick"
                                                ToolTip="Elimina definitivamente dallo storico"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                        <Border x:Name="LoadingOverlay"
                                Background="#CC000000"
                                Visibility="Collapsed"
                                CornerRadius="10">
                            <StackPanel HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <TextBlock Text="🔄" 
                                           FontSize="48" 
                                           HorizontalAlignment="Center"
                                           Foreground="White"/>
                                <TextBlock Text="Caricamento in corso..." 
                                           FontSize="16" 
                                           Margin="0,10,0,0"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <!-- FOOTER -->
                <Grid Grid.Row="4" Margin="22,0,22,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Style="{StaticResource FooterButtonStyle}"
                            Content="Chiudi"
                            Click="OnCloseClick"
                            Background="{StaticResource MutedTextBrush}"
                            FontWeight="Bold"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
