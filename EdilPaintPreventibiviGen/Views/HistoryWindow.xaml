<Window x:Class="EdilPaintPreventibiviGen.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:EdilPaintPreventibiviGen.Models"
        xmlns:converters="clr-namespace:EdilPaintPreventibiviGen.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        RenderOptions.BitmapScalingMode="HighQuality"
        Icon="pack://application:,,,/Assets/Windowsicon/storico.png"
        Title="Storico Preventivi"
        Width="1220"
        Height="760"
        MinWidth="1080"
        MinHeight="640"
        MaxWidth="1540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:SyncStatusToColorConverter x:Key="SyncStatusToColorConverter"/>
        <converters:SyncStatusToTooltipConverter x:Key="SyncStatusToTooltipConverter"/>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModalFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModalFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModalFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
        </Style>

        <Style x:Key="HistoryIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource NeutralButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource NeutralButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource NeutralButtonTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource NeutralButtonHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource NeutralButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource NeutralButtonBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryPdfButtonStyle" TargetType="Button" BasedOn="{StaticResource HistoryIconButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerSoftBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerSoftBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DangerSoftTextBrush}"/>
        </Style>

        <Style x:Key="HistoryDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource HistoryIconButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerSoftBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerSoftHoverBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DangerRedBrush}"/>
        </Style>

        <Style x:Key="DetailActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource NeutralButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource NeutralButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource NeutralButtonTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DetailDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DetailActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerSoftBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerSoftBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DangerRedBrush}"/>
        </Style>

        <Style x:Key="DetailCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="DetailValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ModernHistoryGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DataGridBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DataGridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="62"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SectionPanelBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="62"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Finalizzato">
                    <Setter Property="Background" Value="{StaticResource StatusFinalizzatoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Finalizzato"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusFinalizzatoSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Spedito">
                    <Setter Property="Background" Value="{StaticResource StatusSpeditoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Spedito"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusSpeditoSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BlackBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Confermato">
                    <Setter Property="Background" Value="{StaticResource StatusConfermatoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Confermato"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusConfermatoSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Finito">
                    <Setter Property="Background" Value="{StaticResource StatusFinitoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Finito"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusFinitoSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Rifiutato">
                    <Setter Property="Background" Value="{StaticResource StatusRifiutatoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Rifiutato"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusRifiutatoSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Bozza">
                    <Setter Property="Background" Value="{StaticResource StatusBozzaBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Bozza"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusBozzaSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="DaInviare">
                    <Setter Property="Background" Value="{StaticResource StatusDaInviareBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="DaInviare"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusDaInviareSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="DaSollecitare">
                    <Setter Property="Background" Value="{StaticResource StatusDaSollecitareBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="DaSollecitare"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusDaSollecitareSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BlackBrush}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Archiviato">
                    <Setter Property="Background" Value="{StaticResource StatusArchiviatoBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="Archiviato"/>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource StatusArchiviatoSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource TransparentBrush}">
        <Border Background="{StaticResource RowBackgroundBrush}"
                CornerRadius="16"
                BorderBrush="{StaticResource WindowShadowBorderBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  ShadowDepth="0"
                                  Opacity="0.22"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0"
                      Margin="18,0,10,0"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Storico preventivi"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>
                        <TextBlock Text="Consulta, filtra e gestisci i preventivi già generati"
                                   Margin="0,2,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource HeaderButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Chiudi"
                            Content="✕"/>
                </Grid>

                <!-- DIVIDER -->
                <Border Grid.Row="1" Background="{StaticResource WindowDividerShadowBrush}"/>

                <!-- FILTERS -->
                <Border Grid.Row="2"
                        Margin="22,20,22,14"
                        Background="{StaticResource SectionPanelBackgroundBrush}"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="{StaticResource SectionPanelBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Cerca per cliente, numero o riferimento"/>

                            <TextBox x:Name="TxtSearchHistory"
                                     Grid.Column="0"
                                     Grid.Row="2"
                                     KeyDown="OnSearchKeyDown"/>
                            
                            <Button Grid.Column="1"
                                        Grid.Row="2"
                                        Content="🔍"
                                        Width="38"
                                        Height="38"
                                        Margin="8,0,0,0"
                                        FontSize="16"
                                        Cursor="Hand"
                                        Background="{StaticResource PrimaryBlueBrush}"
                                        Foreground="{StaticResource WhiteBrush}"
                                        BorderThickness="0"
                                        Click="OnSearchButtonClick"
                                        ToolTip="Cerca (Invio)">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource CostsOurBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource CostsOurPressedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Stato"/>

                            <ComboBox x:Name="CboFilterStatus"
                                      Grid.Row="2"
                                      SelectionChanged="OnFilterChanged">
                                <ComboBoxItem Content="Tutti" IsSelected="True"/>
                                <ComboBoxItem Content="Finalizzato"/>
                                <ComboBoxItem Content="Spedito"/>
                                <ComboBoxItem Content="Confermato"/>
                                <ComboBoxItem Content="Finito"/>
                                <ComboBoxItem Content="Rifiutato"/>
                                <ComboBoxItem Content="Bozza"/>
                                <ComboBoxItem Content="DaInviare"/>
                                <ComboBoxItem Content="Archiviato"/>
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Column="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Dal"/>

                            <DatePicker x:Name="DpStart"
                                        Grid.Row="2"
                                        SelectedDateChanged="OnFilterChanged"/>
                        </Grid>

                        <Grid Grid.Column="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Text="Al"/>

                            <DatePicker x:Name="DpEnd"
                                        Grid.Row="2"
                                        SelectedDateChanged="OnFilterChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- TABLE -->
                <Border Grid.Row="3"
                        Margin="22,0,22,18"
                        Background="{StaticResource WhiteBrush}"
                        BorderBrush="{StaticResource DataGridBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="318"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid x:Name="GridHistory"
                                  Grid.Column="0"
                                  ItemsSource="{Binding HistoryView}"
                                  Style="{StaticResource ModernHistoryGridStyle}"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.ScrollUnit="Item">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="12" Height="12" 
                                                 Fill="{Binding SyncStatus, Converter={StaticResource SyncStatusToColorConverter}}"
                                                 ToolTip="{Binding SyncStatus, Converter={StaticResource SyncStatusToTooltipConverter}}"
                                                 Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="N. preventivo" Width="118">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding QuoteNumber}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Cliente / riferimento" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Stretch" Margin="4,0">
                                            <TextBlock Text="{Binding CustomerName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding CustomerName}"/>
                                            <TextBlock Text="{Binding ReferenceName}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ReferenceName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Totale / sconti" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Stretch" Margin="4,0">
                                            <TextBlock Text="{Binding TotalDisplay}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding TotalDisplay}"/>
                                            <TextBlock Text="{Binding DiscountDisplay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding DiscountDisplay}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="IVA" Width="82">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SectionPanelBackgroundBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8,4"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding IvaDisplay}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding IvaType}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Stato" Width="124">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.StatusOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Status, Mode=TwoWay}"
                                                  SelectionChanged="OnStatusChanged"
                                                  Background="{StaticResource TransparentBrush}"
                                                  BorderThickness="0"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Date" Width="122">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding CreatedDateDisplay}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding SentDateDisplay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="" Width="46">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource NotificationRedBrush}"
                                                BorderThickness="0,0,3,0"
                                                Padding="0,0,7,0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                ToolTip="Note presenti">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasNotes}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Note"
                                                       Foreground="{StaticResource NotificationRedBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Azioni" Width="220" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="Apri"
                                                    Width="44"
                                                    Style="{StaticResource HistoryPdfButtonStyle}"
                                                    Click="OnOpenPastQuotePdfClick"
                                                    ToolTip="Apri o rigenera PDF"/>
                                            <Button Content="✏️"
                                                    Width="44"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnEditPastQuoteClick"
                                                    ToolTip="Modifica e aggiorna questo preventivo"/>
                                            <Button Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnNotesClick"
                                                    ToolTip="Apri appunti interni"
                                                    Width="48"
                                                    Height="30"
                                                    Content="{Binding}">
                                                <Button.ContentTemplate>
                                                    <DataTemplate DataType="{x:Type models:QuoteHistorySummary}">
                                                        <Grid Width="36" Height="20">
                                                            <TextBlock Text="Note"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="12"/>
                                                            <Ellipse Width="9" Height="9"
                                                                     Fill="{StaticResource NotificationRedBrush}"
                                                                     HorizontalAlignment="Right"
                                                                     VerticalAlignment="Top"
                                                                     Margin="0,-2,-2,0">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasNotes}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </Grid>
                                                    </DataTemplate>
                                                </Button.ContentTemplate>
                                            </Button>
                                            <Button Content="Altro"
                                                    Width="56"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnMoreActionsClick"
                                                    ToolTip="Altre azioni e dettagli"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="220" Header="Azioni" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="🔄"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnCopyPastQuoteClick"
                                                    ToolTip="Copia in un nuovo preventivo"/>
                                            <Button Content="✏️"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnEditPastQuoteClick"
                                                    ToolTip="Modifica e aggiorna questo preventivo"/>
                                            <Button Content="📁"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnOpenCustomerFolderClick"
                                                    ToolTip="Apri cartella cliente"/>
                                            <Button Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnNotesClick"
                                                    ToolTip="Apri appunti interni"
                                                    Width="30" Height="30"
                                                    Content="{Binding}">
                                                <Button.ContentTemplate>
                                                    <DataTemplate DataType="{x:Type models:QuoteHistorySummary}">
                                                        <Grid Width="20" Height="20">
                                                            <TextBlock Text="📝"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="14"/>
                                                            <Ellipse Width="9" Height="9"
                                                                     Fill="{StaticResource NotificationRedBrush}"
                                                                     HorizontalAlignment="Right"
                                                                     VerticalAlignment="Top"
                                                                     Margin="0,-2,-2,0">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasNotes}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </Grid>
                                                    </DataTemplate>
                                                </Button.ContentTemplate>
                                            </Button>
                                            <Button Content="Inv"
                                                    Style="{StaticResource HistoryIconButtonStyle}"
                                                    Click="OnSendQuoteClick"
                                                    ToolTip="Registra invio"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Data"
                                                Visibility="Collapsed"
                                                Binding="{Binding Date, StringFormat=dd/MM/yyyy}"
                                                IsReadOnly="True"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="N. Prev"
                                                Visibility="Collapsed"
                                                Binding="{Binding QuoteNumber}"
                                                IsReadOnly="True"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Cliente"
                                                Visibility="Collapsed"
                                                Binding="{Binding CustomerName}"
                                                IsReadOnly="True"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding CustomerName}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Riferimento"
                                                Visibility="Collapsed"
                                                Binding="{Binding ReferenceName}"
                                                IsReadOnly="True"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding ReferenceName}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Totale (€)"
                                                Visibility="Collapsed"
                                                Binding="{Binding Total, StringFormat={}{0:N2}}"
                                                IsReadOnly="True"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Stato" Width="170" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.StatusOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Status, Mode=TwoWay}"
                                                  SelectionChanged="OnStatusChanged"
                                                  Background="{StaticResource TransparentBrush}"
                                                  BorderThickness="0"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Invio"
                                                Visibility="Collapsed"
                                                Binding="{Binding SentDisplay}"
                                                IsReadOnly="True"
                                                Width="140"/>

                            <DataGridTextColumn Header="PC"
                                                Visibility="Collapsed"
                                                Binding="{Binding LastModifiedByDevice}"
                                                IsReadOnly="True"
                                                Width="120"/>

                            <DataGridTemplateColumn Header="" Width="54" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🔍"
                                                Style="{StaticResource HistoryPdfButtonStyle}"
                                                Click="OnOpenPastQuotePdfClick"
                                                ToolTip="Apri il PDF, oppure la cartella se il file non esiste"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="" Width="54" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️"
                                                Style="{StaticResource HistoryDeleteButtonStyle}"
                                                Click="OnDeletePastQuoteClick"
                                                ToolTip="Elimina definitivamente dallo storico"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                        <Border Grid.Column="2"
                                Background="{StaticResource SectionPanelBackgroundBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16"
                                DataContext="{Binding SelectedItem, ElementName=GridHistory}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Dettaglio preventivo"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DefaultTextBrush}"/>
                                    <TextBlock Text="{Binding QuoteNumber, TargetNullValue=Seleziona una riga}"
                                               Margin="0,4,0,0"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource DefaultTextBrush}"/>
                                    <TextBlock Text="{Binding CustomerReferenceDisplay}"
                                               Margin="0,2,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"/>

                                    <WrapPanel Margin="0,0,0,8">
                                        <Button Content="Apri PDF"
                                                Style="{StaticResource DetailActionButtonStyle}"
                                                Click="OnOpenPastQuotePdfClick"/>
                                        <Button Content="Modifica"
                                                Style="{StaticResource DetailActionButtonStyle}"
                                                Click="OnEditPastQuoteClick"/>
                                        <Button Style="{StaticResource DetailActionButtonStyle}"
                                                Click="OnNotesClick"
                                                Content="Note"/>
                                        <Button Content="Invia"
                                                Style="{StaticResource DetailActionButtonStyle}"
                                                Click="OnSendQuoteClick"/>
                                        <Button Content="Certificato posa"
                                                Style="{StaticResource DetailActionButtonStyle}"
                                                Click="OnGenerateInstallationCertificateClick"/>
                                        <Button Content="Cartella"
                                                Style="{StaticResource DetailActionButtonStyle}"
                                                Click="OnOpenCustomerFolderClick"/>
                                        <Button Content="Copia"
                                                Style="{StaticResource DetailActionButtonStyle}"
                                                Click="OnCopyPastQuoteClick"/>
                                        <Button Content="Elimina"
                                                Style="{StaticResource DetailDangerButtonStyle}"
                                                Click="OnDeletePastQuoteClick"/>
                                    </WrapPanel>

                                    <Separator Margin="0,4,0,14"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="Totale" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding TotalDisplay}" Style="{StaticResource DetailValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="IVA" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding IvaDisplay}" Style="{StaticResource DetailValueStyle}" ToolTip="{Binding IvaType}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0">
                                            <TextBlock Text="Sconti" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding DiscountDisplay}" Style="{StaticResource DetailValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="2">
                                            <TextBlock Text="Stato" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource DetailValueStyle}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="4" Grid.Column="0">
                                            <TextBlock Text="Creazione" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding CreatedDateDisplay}" Style="{StaticResource DetailValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="4" Grid.Column="2">
                                            <TextBlock Text="Invio" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding SentDateDisplay}" Style="{StaticResource DetailValueStyle}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                            <TextBlock Text="Destinatario" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding SentRecipient, TargetNullValue=-}" Style="{StaticResource DetailValueStyle}" ToolTip="{Binding SentRecipient}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="8" Grid.Column="0">
                                            <TextBlock Text="Inviato da" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding SentByDevice}" Style="{StaticResource DetailValueStyle}" ToolTip="{Binding SentByDevice}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="8" Grid.Column="2">
                                            <TextBlock Text="PC" Style="{StaticResource DetailCaptionStyle}"/>
                                            <TextBlock Text="{Binding LastModifiedByDevice}" Style="{StaticResource DetailValueStyle}" ToolTip="{Binding LastModifiedByDevice}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border x:Name="LoadingOverlay"
                                Grid.ColumnSpan="3"
                                Background="{StaticResource OverlayBackdropBrush}"
                                Visibility="Collapsed"
                                CornerRadius="10">
                            <StackPanel HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <TextBlock Text="🔄" 
                                           FontSize="48" 
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource WhiteBrush}"/>
                                <TextBlock Text="Caricamento in corso..." 
                                           FontSize="16" 
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource WhiteBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <!-- FOOTER -->
                <Grid Grid.Row="4" Margin="22,0,22,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Style="{StaticResource FooterButtonStyle}"
                            Content="Chiudi"
                            Click="OnCloseClick"
                            Background="{StaticResource SettingsButtonBrush}"
                            FontWeight="Bold"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
