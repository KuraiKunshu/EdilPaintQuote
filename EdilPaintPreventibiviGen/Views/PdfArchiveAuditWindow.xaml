<Window x:Class="EdilPaintPreventibiviGen.Views.PdfArchiveAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controllo PDF"
        Width="1050"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ShellBackgroundBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.ico">
    <DockPanel Margin="18">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Controllo PDF e allegati"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DefaultTextBrush}"/>
                <TextBlock x:Name="TxtStatus"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Pronto"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Scansiona"
                        Width="105"
                        Height="34"
                        Margin="0,0,8,0"
                        Background="{StaticResource DiagnosticsButtonBrush}"
                        Foreground="{StaticResource WhiteBrush}"
                        BorderThickness="0"
                        Click="OnScanClick"/>
                <Button Content="Ripristina"
                        Width="105"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnRestoreClick"/>
                <Button Content="Chiudi"
                        Width="80"
                        Height="34"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <DataGrid x:Name="GridIssues"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N." Binding="{Binding QuoteNumber}" Width="95"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="210"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding TypeDisplay}" Width="185"/>
                    <DataGridTextColumn Header="Stato" Binding="{Binding RestoreDisplay}" Width="115"/>
                    <DataGridTextColumn Header="Dettaglio" Binding="{Binding Details}" Width="260"/>
                    <DataGridTextColumn Header="Percorso atteso" Binding="{Binding ExpectedPath}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
