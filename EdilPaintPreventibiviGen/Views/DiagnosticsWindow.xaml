<Window x:Class="EdilPaintPreventibiviGen.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Diagnostica"
        Width="860"
        Height="760"
        MinWidth="780"
        MinHeight="560"
        MaxWidth="1180"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.png">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Background" Value="{StaticResource DiagnosticsButtonBrush}"/>
        </Style>

        <Style x:Key="SectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SectionPanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,12,8"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource TransparentBrush}">
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource WindowShadowBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.22"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="58"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="18,0,10,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Diagnostica"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>
                        <TextBlock Text="Stato locale, sincronizzazione, updater e impostazioni"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource HeaderButtonStyle}"
                            Content="R"
                            ToolTip="Aggiorna"
                            Click="OnRefreshClick"/>
                    <Button Grid.Column="2"
                            Style="{StaticResource HeaderButtonStyle}"
                            Content="X"
                            ToolTip="Chiudi"
                            Click="OnCloseClick"/>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource SubtleBorderBrush}"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,18">
                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Stato applicazione"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Versione"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtAppVersion"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Database"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtDatabaseStatus"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Template PDF"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtPdfTemplate"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Updater"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtUpdaterStatus"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Sincronizzazione"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Stato"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtSyncStatus"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Ultima sync"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtLastSync"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Patch preventivi"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtPendingQuotePatches"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Eliminazioni"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtPendingDeletes"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Percorsi"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Programma"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtExecutablePath"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Appsettings"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtSettingsPath"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Dati locali"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtLocalDataPath"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Radice PDF"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtPdfRootPath"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Stato updater"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueStyle}" x:Name="TxtUpdaterStatePath"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Azioni"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,12"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Content="Esporta impostazioni"
                                            Margin="0,0,8,8"
                                            Click="OnExportSettingsClick"/>
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Content="Importa impostazioni"
                                            Margin="0,0,8,8"
                                            Background="{StaticResource SecondaryBlueBrush}"
                                            Click="OnImportSettingsClick"/>
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Content="Cartella impostazioni"
                                            Margin="0,0,8,8"
                                            Background="{StaticResource SettingsButtonBrush}"
                                            Click="OnOpenSettingsFolderClick"/>
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Content="Cartella dati"
                                            Margin="0,0,8,8"
                                            Background="{StaticResource SettingsButtonBrush}"
                                            Click="OnOpenDataFolderClick"/>
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Content="Cartella PDF"
                                            Margin="0,0,8,8"
                                            Background="{StaticResource SettingsButtonBrush}"
                                            Click="OnOpenPdfFolderClick"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="3" Margin="20,0,20,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="Chiudi"
                            Width="110"
                            Background="{StaticResource ModalPrimaryActionBrush}"
                            Click="OnCloseClick"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
