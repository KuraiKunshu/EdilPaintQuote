<Window x:Class="EdilPaintPreventibiviGen.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Width="920"
        Height="640"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ShellBackgroundBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.ico">
    <Window.Resources>
        <Style x:Key="TileStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>
        <Style x:Key="TileLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
        </Style>
        <Style x:Key="TileValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="18">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Dashboard"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DefaultTextBrush}"/>
                <TextBlock x:Name="TxtSubtitle"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Aggiorna"
                        Width="92"
                        Height="34"
                        Margin="0,0,8,0"
                        Background="{StaticResource DiagnosticsButtonBrush}"
                        Foreground="{StaticResource WhiteBrush}"
                        BorderThickness="0"
                        Click="OnRefreshClick"/>
                <Button Content="Chiudi"
                        Width="78"
                        Height="34"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="4">
                <Border Style="{StaticResource TileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileLabelStyle}" Text="Preventivi totali"/>
                        <TextBlock x:Name="TxtTotalQuotes" Style="{StaticResource TileValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileLabelStyle}" Text="Da sollecitare"/>
                        <TextBlock x:Name="TxtToRemind" Style="{StaticResource TileValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileLabelStyle}" Text="PDF da controllare"/>
                        <TextBlock x:Name="TxtPdfIssues" Style="{StaticResource TileValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TileLabelStyle}" Text="Bozza locale"/>
                        <TextBlock x:Name="TxtDraftState" Style="{StaticResource TileValueStyle}" FontSize="18"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource TileStyle}">
                    <StackPanel>
                        <TextBlock Text="Stato PC"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"
                                   Margin="0,0,0,12"/>
                        <TextBlock x:Name="TxtDevice" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtDatabase" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtSync" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtPending" TextWrapping="Wrap"/>

                        <WrapPanel Margin="0,18,0,0">
                            <Button Content="Storico"
                                    Width="90"
                                    Height="32"
                                    Margin="0,0,8,8"
                                    Click="OnHistoryClick"/>
                            <Button Content="Controllo PDF"
                                    Width="118"
                                    Height="32"
                                    Margin="0,0,8,8"
                                    Click="OnPdfAuditClick"/>
                            <Button Content="Diagnostica"
                                    Width="106"
                                    Margin="0,0,8,8"
                                    Height="32"
                                    Click="OnDiagnosticsClick"/>
                            <Button Content="Sync ora"
                                    Width="96"
                                    Height="32"
                                    Click="OnSyncNowClick"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource TileStyle}" Margin="0,0,0,12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Preventivi da seguire"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"
                                   Margin="0,0,0,12"/>
                        <DataGrid x:Name="GridReminders"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="N." Binding="{Binding QuoteNumber}" Width="90"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Invio" Binding="{Binding SentDisplay}" Width="130"/>
                                <DataGridTextColumn Header="Solleciti" Binding="{Binding ReminderDisplay}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
