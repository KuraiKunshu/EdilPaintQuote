<Window x:Class="EdilPaintPreventibiviGen.Views.QuoteSendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registra invio"
        Width="430"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ShellBackgroundBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.ico">
    <StackPanel Margin="20">
        <TextBlock Text="Registra invio preventivo"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource DefaultTextBrush}"
                   Margin="0,0,0,16"/>

        <TextBlock Text="Metodo" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="CboMethod"
                  Height="32"
                  Margin="0,0,0,12"
                  IsEditable="True">
            <ComboBoxItem Content="Email" IsSelected="True"/>
            <ComboBoxItem Content="WhatsApp"/>
            <ComboBoxItem Content="Telefono"/>
            <ComboBoxItem Content="A mano"/>
        </ComboBox>

        <TextBlock Text="Destinatario" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtRecipient"
                 Height="32"
                 Margin="0,0,0,12"
                 VerticalContentAlignment="Center"/>

        <TextBlock Text="Data invio" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <DatePicker x:Name="DpSentDate"
                    Height="32"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Annulla" Width="90" Height="32" Margin="0,0,8,0" Click="OnCancelClick"/>
            <Button Content="Salva" Width="90" Height="32"
                    Background="{StaticResource GeneratePdfButtonBrush}"
                    Foreground="{StaticResource WhiteBrush}"
                    BorderThickness="0"
                    Click="OnSaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>
