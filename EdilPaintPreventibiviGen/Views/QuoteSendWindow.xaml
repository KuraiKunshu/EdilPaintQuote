<Window x:Class="EdilPaintPreventibiviGen.Views.QuoteSendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invio preventivo"
        Width="560"
        Height="700"
        MinWidth="520"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource ShellBackgroundBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.ico">

    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModalFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,18">
            <StackPanel>
                <TextBlock x:Name="TxtQuoteTitle"
                           Text="Invio preventivo"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DefaultTextBrush}"/>
                <TextBlock x:Name="TxtQuoteSubtitle"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,18">
                <TextBlock Text="Email destinatario"
                           Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="TxtRecipient"
                         Style="{StaticResource FieldTextBoxStyle}"/>

                <TextBlock Text="Email in copia"
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="0,12,0,5"/>
                <TextBox x:Name="TxtCcRecipients"
                         Style="{StaticResource FieldTextBoxStyle}"/>

                <Border x:Name="EmailFieldsPanel"
                        Background="{StaticResource SectionPanelBackgroundBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Oggetto email" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtSubject"
                                 Style="{StaticResource FieldTextBoxStyle}"/>

                        <TextBlock Text="Testo email"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,14,0,5"/>
                        <TextBox x:Name="TxtBody"
                                 MinHeight="150"
                                 Padding="9,7"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{StaticResource WhiteBrush}"
                                 BorderBrush="{StaticResource ModalFieldBorderBrush}"
                                 BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SectionPanelBackgroundBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,16,0,0">
                    <StackPanel>
                        <CheckBox x:Name="ChkSendWhatsApp"
                                  Content="Prepara messaggio WhatsApp"
                                  FontWeight="SemiBold"
                                  Foreground="{StaticResource DefaultTextBrush}"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Numero WhatsApp" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtWhatsAppPhone"
                                 Style="{StaticResource FieldTextBoxStyle}"/>

                        <TextBlock Text="Messaggio WhatsApp"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,14,0,5"/>
                        <TextBox x:Name="TxtWhatsAppMessage"
                                 MinHeight="90"
                                 Padding="9,7"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{StaticResource WhiteBrush}"
                                 BorderBrush="{StaticResource ModalFieldBorderBrush}"
                                 BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtActionHint"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"/>

                <Button Grid.Column="1"
                        Style="{StaticResource FooterButtonStyle}"
                        Content="Annulla"
                        Background="{StaticResource MutedTextBrush}"
                        Click="OnCancelClick"/>
                <Button Grid.Column="3"
                        x:Name="BtnSave"
                        Style="{StaticResource FooterButtonStyle}"
                        Content="Salva invio"
                        Background="{StaticResource ModalPrimaryActionBrush}"
                        Click="OnSaveClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>
