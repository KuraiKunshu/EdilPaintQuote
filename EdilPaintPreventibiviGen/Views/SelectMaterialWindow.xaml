<Window x:Class="EdilPaintPreventibiviGen.Views.SelectMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Materiali locali"
        Width="900"
        Height="1000"
        MinWidth="860"
        MinHeight="620"
        MaxWidth="1280"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.png">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModalFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DeleteActionBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DataGridBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DataGridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SectionPanelBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SearchResultHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SearchResultSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource TransparentBrush}">
        <Border Background="{StaticResource RowBackgroundBrush}"
                CornerRadius="16"
                BorderBrush="{StaticResource WindowShadowBorderBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.22"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="18,0,10,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Anagrafica materiali locali"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>
                        <TextBlock Text="Aggiungi, modifica o rimuovi i materiali salvati localmente"
                                   Margin="0,2,0,0" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="1" Style="{StaticResource HeaderButtonStyle}"
                            Click="CloseButton_Click" ToolTip="Chiudi" Content="✕"/>
                </Grid>

                <!-- DIVIDER -->
                <Border Grid.Row="1" Background="{StaticResource WindowDividerShadowBrush}"/>

                <!-- CONTENT -->
                <Grid Grid.Row="2" Margin="22,20,22,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- FORM -->
                    <Border Grid.Row="0" Padding="18" CornerRadius="12"
                            Background="{StaticResource SectionPanelBackgroundBrush}" BorderBrush="{StaticResource SectionPanelBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock x:Name="TxtFormTitle" Text="Nuovo materiale"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"/>
                                <TextBlock Text="Seleziona un materiale in basso per modificarlo, oppure compila i campi per crearne uno nuovo."
                                           Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <!-- Nome + Prezzo + BS -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{StaticResource SectionLabelStyle}" Text="Nome"/>
                                    <TextBox x:Name="TxtName" Grid.Row="2"/>
                                </Grid>

                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{StaticResource SectionLabelStyle}" Text="Prezzo unitario (€)"/>
                                    <TextBox x:Name="TxtPrice" Grid.Row="2"/>
                                </Grid>

                                <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,6">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Bene significativo" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="ChkSignificant" Content="Sì, è un bene significativo"
                                              VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </Grid>

                            <!-- Descrizione -->
                            <Grid Grid.Row="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource SectionLabelStyle}" Text="Descrizione"/>
                                <TextBox x:Name="TxtDesc" Grid.Row="2" Height="84" MinHeight="84" MaxHeight="120"
                                         Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>
                            </Grid>

                            <!-- Buttons -->
                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="1" Style="{StaticResource FooterButtonStyle}"
                                        Content="Nuovo" Click="OnResetClick"
                                        Background="{StaticResource MutedTextBrush}"/>

                                <Button x:Name="BtnSaveMaterial" Grid.Column="3"
                                        Style="{StaticResource FooterButtonStyle}"
                                        Content="Salva in anagrafica"
                                        Click="OnSaveMaterialClick"
                                        Background="{StaticResource ModalPrimaryActionBrush}"
                                        FontWeight="Bold" Width="170"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Search -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Cerca materiale"
                                   FontWeight="SemiBold" Foreground="{StaticResource DefaultTextBrush}"/>
                        <TextBox x:Name="TxtSearch" Grid.Row="2" TextChanged="OnSearchTextChanged"/>
                    </Grid>

                    <!-- TABLE -->
                    <Border Grid.Row="4" Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource DataGridBorderBrush}"
                            BorderThickness="1" CornerRadius="10" SnapsToDevicePixels="True">
                        <DataGrid x:Name="GridMaterials"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  SelectionChanged="OnMaterialSelectionChanged"
                                  Margin="0" HeadersVisibility="Column" RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="220">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="ToolTip" Value="{Binding Name}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="ToolTip" Value="{Binding Description}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Valore €"
                                                    Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridCheckBoxColumn Header="B.S." Binding="{Binding IsSignificant}" Width="50" IsReadOnly="True"/>

                                <DataGridTemplateColumn Header="" Width="56" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource DeleteButtonStyle}"
                                                    Content="🗑" Click="OnDeleteMaterialClick"
                                                    ToolTip="Elimina da anagrafica"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- FOOTER -->
                <Grid Grid.Row="3" Margin="22,0,22,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Style="{StaticResource FooterButtonStyle}"
                            Content="Chiudi" Click="OnCancelClick"
                            Background="{StaticResource MutedTextBrush}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
