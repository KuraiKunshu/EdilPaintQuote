<Window x:Class="EdilPaintPreventibiviGen.Views.VeluxLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Login VELUX" Height="750" Width="1000" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Istruzioni -->
            <RowDefinition Height="*"/>    <!-- Browser -->
            <RowDefinition Height="Auto"/> <!-- Pulsante -->
        </Grid.RowDefinitions>
        
        <Border Background="#3498db" Padding="15">
            <TextBlock Text="Esegui il login VELUX. Una volta caricata la dashboard principale, clicca il pulsante verde in basso." 
                       Foreground="White" FontWeight="Bold" TextAlignment="Center" FontSize="14"/>
        </Border>

        <wv2:WebView2 x:Name="WebView" Grid.Row="1" Source="https://app.velux.it/cas/login"/>
        
        <Border Grid.Row="2" Background="#f8f9fa" Padding="15" BorderBrush="#ddd" BorderThickness="0,1,0,0">
            <Button Content="CONFERMA LOGIN E PROCEDI" Height="50" Width="300" 
                    Background="#1abc9c" Foreground="White" FontSize="16" FontWeight="Bold" 
                    BorderThickness="0" Cursor="Hand" Click="OnConfirmLoginClick"/>
        </Border>
    </Grid>
</Window>