<Window x:Class="EdilPaintPreventibiviGen.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Impostazioni"
        Width="760"
        Height="790"
        MinWidth="760"
        MinHeight="620"
        MaxWidth="980"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.png">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModalFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModalFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="SectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SectionPanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource TransparentBrush}">
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource WindowShadowBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.22"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="58"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="18,0,10,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Impostazioni applicazione"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>
                        <TextBlock Text="Configura il comportamento locale di questo PC"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource HeaderButtonStyle}"
                            Content="X"
                            ToolTip="Chiudi"
                            Click="OnCancelClick"/>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource SubtleBorderBrush}"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,18">
                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Connessione database"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Tipo database"/>
                                        <ComboBox x:Name="CmbDatabaseProvider"
                                                  Height="34"
                                                  Background="{StaticResource WhiteBrush}"
                                                  BorderBrush="{StaticResource ModalFieldBorderBrush}"
                                                  BorderThickness="1"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Porta"/>
                                        <TextBox x:Name="TxtDatabasePort"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Server / host"/>
                                        <TextBox x:Name="TxtDatabaseServer"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Database"/>
                                        <TextBox x:Name="TxtDatabaseName"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="User"/>
                                        <TextBox x:Name="TxtDatabaseUsername"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Password"/>
                                        <PasswordBox x:Name="TxtDatabasePassword"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource HintStyle}"
                                           Text="Per Neon/PostgreSQL usa porta 5432 salvo indicazioni diverse. Tutti i valori sensibili vengono salvati cifrati per questo utente Windows."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Comportamento"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkGeneratePdf"
                                          Content="Abilita generazione PDF"
                                          Margin="0,0,0,9"/>
                                <CheckBox x:Name="ChkRestoreMissingPdfsOnStartup"
                                          Content="Ripristina automaticamente i PDF mancanti all'avvio (puo' essere lento)"
                                          Margin="0,0,0,9"/>
                                <CheckBox x:Name="ChkDatabaseCostSavingMode"
                                          Content="Modalita' risparmio DB dal prossimo avvio (disattiva la sincronizzazione automatica ogni 5 minuti)"
                                          Margin="0,0,0,9"/>
                                <CheckBox x:Name="ChkSilentStartup"
                                          Content="Chiudi silenziosamente l'app se si verifica un errore durante l'avvio"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Aggiornamenti"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DefaultTextBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               Text="Avvia lo script updater configurato su questo PC. L'applicazione verra' chiusa per permettere la sostituzione dei file."/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Aggiorna ora"
                                        Width="130"
                                        Height="34"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource ModalPrimaryActionBrush}"
                                        Foreground="{StaticResource WhiteBrush}"
                                        BorderThickness="0"
                                        Click="OnRunUpdaterClick"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Integrazione Velux"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DefaultTextBrush}"
                                               Margin="0,0,0,10"/>
                                    <CheckBox x:Name="ChkUseVeluxLogin"
                                              Content="Cerca anche nel catalogo Velux durante la ricerca materiali"/>
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               Text="Il login viene richiesto nel browser integrato e la sessione resta salvata solo su questo PC."/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Rimuovi sessione"
                                        Width="130"
                                        Height="32"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Bottom"
                                        Background="{StaticResource DangerRedBrush}"
                                        Foreground="{StaticResource WhiteBrush}"
                                        BorderThickness="0"
                                        Click="OnClearVeluxSessionClick"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Invio email"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkMailEnabled"
                                          Content="Abilita invio preventivi via SMTP"
                                          Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Server SMTP"/>
                                        <TextBox x:Name="TxtMailSmtpServer"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Porta"/>
                                        <TextBox x:Name="TxtMailPort"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="4"
                                              x:Name="ChkMailUseSsl"
                                              Content="SSL/TLS"
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,0,8"/>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="User / email Libero"/>
                                        <TextBox x:Name="TxtMailUsername"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Password"/>
                                        <PasswordBox x:Name="TxtMailPassword"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Email mittente"/>
                                        <TextBox x:Name="TxtMailSenderEmail"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Nome mittente"/>
                                        <TextBox x:Name="TxtMailSenderName"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Oggetto predefinito"
                                           Margin="0,12,0,5"/>
                                <TextBox x:Name="TxtMailSubject"/>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Testo predefinito"
                                           Margin="0,12,0,5"/>
                                <TextBox x:Name="TxtMailBody"
                                         Height="86"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBlock Style="{StaticResource HintStyle}"
                                           Text="Parametri Libero: smtp.libero.it, porta 465, SSL/TLS. Segnaposto disponibili: {QuoteNumber}, {CustomerName}, {ReferenceName}, {Date}, {Total}."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Archiviazione PDF"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,12"/>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Cartella principale PDF"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtPdfRootPath"/>
                                    <Button Grid.Column="2"
                                            Content="Sfoglia"
                                            Width="86"
                                            Height="34"
                                            Background="{StaticResource SecondaryBlueBrush}"
                                            Foreground="{StaticResource WhiteBrush}"
                                            BorderThickness="0"
                                            Click="OnBrowsePdfRootClick"/>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Sottocartella storico"/>
                                        <TextBox x:Name="TxtHistorySubFolder"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Numero risultati nello storico"/>
                                        <TextBox x:Name="TxtHistoryResultLimit"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Formato cartella cliente"
                                           Margin="0,12,0,5"/>
                                <TextBox x:Name="TxtCustomerFolderPattern"/>
                                <TextBlock Style="{StaticResource HintStyle}"
                                           Text="Segnaposto disponibili: {CustomerName}, {ReferenceName}"/>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Formato nome PDF"
                                           Margin="0,12,0,5"/>
                                <TextBox x:Name="TxtPdfFileNamePattern"/>
                                <TextBlock Style="{StaticResource HintStyle}"
                                           Text="Segnaposto disponibili: {CustomerName}, {ReferenceName}, {QuoteNumber}, {Date}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Template PDF"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Template attivo"/>
                                        <ComboBox x:Name="CmbPdfTemplate"
                                                  Height="34"
                                                  Background="{StaticResource WhiteBrush}"
                                                  BorderBrush="{StaticResource ModalFieldBorderBrush}"
                                                  BorderThickness="1"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Firma"/>
                                        <TextBox x:Name="TxtPdfSignatureText"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Titolo note"
                                           Margin="0,12,0,5"/>
                                <TextBox x:Name="TxtPdfNotesTitle"/>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Footer PDF"
                                           Margin="0,12,0,5"/>
                                <TextBox x:Name="TxtPdfFooterText"
                                         Height="58"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"
                                         VerticalScrollBarVisibility="Auto"/>
                                <CheckBox x:Name="ChkPdfShowTemplateName"
                                          Content="Mostra nome template nel PDF"
                                          Margin="0,10,0,0"/>
                                <Button Content="Anteprima template"
                                        Width="150"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        Margin="0,12,0,0"
                                        Background="{StaticResource SecondaryBlueBrush}"
                                        Foreground="{StaticResource WhiteBrush}"
                                        BorderThickness="0"
                                        Click="OnPreviewPdfTemplateClick"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Avanzate"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DefaultTextBrush}"
                                           Margin="0,0,0,10"/>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Cartella temporanea"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtTempPath"/>
                                    <Button Grid.Column="2"
                                            Content="Sfoglia"
                                            Width="86"
                                            Height="34"
                                            Background="{StaticResource SecondaryBlueBrush}"
                                            Foreground="{StaticResource WhiteBrush}"
                                            BorderThickness="0"
                                            Click="OnBrowseTempPathClick"/>
                                </Grid>
                                <TextBlock Style="{StaticResource HintStyle}"
                                           Text="Se lasciato vuoto viene usata automaticamente la cartella temporanea di Windows."/>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Nome dispositivo"
                                           Margin="0,12,0,5"/>
                                <TextBox x:Name="TxtDeviceName"/>
                                <TextBlock Style="{StaticResource HintStyle}"
                                           Text="Nome usato nei log, nello storico e nella sincronizzazione multi PC."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="3" Margin="20,0,20,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
                            Style="{StaticResource FooterButtonStyle}"
                            Content="Annulla"
                            Width="110"
                            Background="{StaticResource MutedTextBrush}"
                            Click="OnCancelClick"/>
                    <Button Grid.Column="3"
                            Style="{StaticResource FooterButtonStyle}"
                            Content="Salva"
                            Width="110"
                            Background="{StaticResource ModalPrimaryActionBrush}"
                            Click="OnSaveClick"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
