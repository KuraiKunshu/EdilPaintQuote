<Window x:Class="EdilPaintPreventibiviGen.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/Assets/Windowsicon/main.ico"
        Title="Caricamento">

    <Grid Margin="18" Background="Transparent">
        <Border Padding="24"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.18"/>
            </Border.Effect>

            <StackPanel Width="340">
                <Border Background="#FFF1F5F9"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,0,14">
                    <TextBlock Text="EdilPaint"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#991B1B"
                               HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Text="Caricamento in corso"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                <TextBlock Text="{Binding StatusText, RelativeSource={RelativeSource AncestorType=Window}}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="#6B7280"
                           Margin="0,0,0,16"/>

                <ProgressBar Height="16"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="{Binding IsLoading, RelativeSource={RelativeSource AncestorType=Window}}"
                             Background="#F3F4F6"
                             Foreground="#D32F2F"/>

                <TextBlock Text="Attendere..."
                           FontSize="11"
                           Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
