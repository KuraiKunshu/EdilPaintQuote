<Window x:Class="EdilPaintPreventibiviGen.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.ico"
        Title="Caricamento">

    <Grid Margin="18" Background="{StaticResource TransparentBrush}">
        <Border Padding="24"
                Background="{StaticResource WhiteBrush}"
                BorderBrush="{StaticResource LoadingBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.18"/>
            </Border.Effect>

            <StackPanel Width="340">
                <Border Background="{StaticResource LoadingIconBackgroundBrush}"
                        BorderBrush="{StaticResource LoadingIconBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,0,14">
                    <TextBlock Text="EdilPaint"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource LoadingIconForegroundBrush}"
                               HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Text="Caricamento in corso"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource LoadingTitleBrush}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="{Binding StatusText, RelativeSource={RelativeSource AncestorType=Window}}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource LoadingMessageBrush}"
                           Margin="0,0,0,16"/>

                <ProgressBar Height="16"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="{Binding IsLoading, RelativeSource={RelativeSource AncestorType=Window}}"
                             Background="{StaticResource LoadingProgressBackgroundBrush}"
                             Foreground="{StaticResource MaterialRedBrush}"/>

                <TextBlock Text="Attendere..."
                           FontSize="11"
                           Foreground="{StaticResource LoadingDetailBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
