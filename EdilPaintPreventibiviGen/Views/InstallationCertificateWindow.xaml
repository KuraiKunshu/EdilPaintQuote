<Window x:Class="EdilPaintPreventibiviGen.Views.InstallationCertificateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Certificato corretta posa"
        Width="540"
        Height="420"
        MinWidth="500"
        MinHeight="390"
        MaxWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackgroundBrush}"
        Icon="pack://application:,,,/Assets/Windowsicon/main.ico">

    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,18">
            <StackPanel>
                <TextBlock x:Name="TxtTitle"
                           Text="Certificato di corretta posa"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DefaultTextBrush}"/>
                <TextBlock x:Name="TxtSubtitle"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="22,20"
                Padding="18"
                Background="{StaticResource SectionPanelBackgroundBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Data di fine lavori"
                           Style="{StaticResource FieldLabelStyle}"/>
                <DatePicker x:Name="DpCompletionDate"
                            Grid.Row="1"
                            Height="36"
                            Padding="8,4"/>

                <TextBlock Grid.Row="3"
                           Text="Cantiere presso (facoltativo)"
                           Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="TxtWorkSite"
                         Grid.Row="4"
                         Height="38"
                         Padding="10,6"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource WhiteBrush}"
                         BorderBrush="{StaticResource ModalFieldBorderBrush}"
                         BorderThickness="1"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla"
                        Style="{StaticResource FooterButtonStyle}"
                        Background="{StaticResource MutedTextBrush}"
                        Click="OnCancelClick"/>
                <Button Content="Genera certificato"
                        Margin="10,0,0,0"
                        MinWidth="158"
                        Style="{StaticResource FooterButtonStyle}"
                        Background="{StaticResource ModalPrimaryActionBrush}"
                        Click="OnGenerateClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
