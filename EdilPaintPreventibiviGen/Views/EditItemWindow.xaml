<Window x:Class="EdilPaintPreventibiviGen.Views.EditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Modifica Voce"
        Width="560"
        Height="530"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/Assets/Windowsicon/main.png"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent" Margin="18">
        <Border Background="{StaticResource RowBackgroundBrush}"
                CornerRadius="16"
                BorderBrush="#22000000"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  ShadowDepth="0"
                                  Opacity="0.22"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0"
                      Margin="18,0,10,0"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Modifica voce"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>
                        <TextBlock Text="Aggiorna nome, descrizione, prezzo e quantità"
                                   Margin="0,2,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource HeaderButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Chiudi"
                            Content="✕"/>
                </Grid>

                <!-- DIVIDER -->
                <Border Grid.Row="1" Background="#18000000"/>

                <!-- CONTENT -->
                <Grid Grid.Row="2" Margin="22,20,22,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nome -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Nome"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>

                        <TextBox x:Name="TxtName"
                                 Grid.Row="2"/>
                    </Grid>

                    <!-- Descrizione -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Descrizione"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DefaultTextBrush}"/>

                        <TextBox x:Name="TxtDescription"
                                 Grid.Row="2"
                                 Height="92"
                                 MinHeight="92"
                                 MaxHeight="120"
                                 Padding="10,8"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>

                    <!-- Prezzo + Quantità -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Prezzo unitario (€)"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DefaultTextBrush}"/>

                            <TextBox x:Name="TxtPrice"
                                     Grid.Row="2"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Quantità"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DefaultTextBrush}"/>

                            <TextBox x:Name="TxtQty"
                                     Grid.Row="2"/>
                        </Grid>
                    </Grid>

                    <!-- Checkbox -->
                    <Border Grid.Row="6"
                            Padding="12"
                            CornerRadius="10"
                            Background="#F6F8FA"
                            BorderBrush="#12000000"
                            BorderThickness="1">
                        <CheckBox x:Name="ChkSignificant"
                                  Content="Bene significativo (per IVA RC)"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource DefaultTextBrush}"
                                  FontWeight="Medium"/>
                    </Border>

                    <!-- Nota -->
                    <TextBlock Grid.Row="8"
                               Text="Controlla con attenzione prezzo e quantità prima di salvare."
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </Grid>

                <!-- FOOTER -->
                <Grid Grid.Row="3" Margin="22,0,22,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Style="{StaticResource FooterButtonStyle}"
                            Content="Annulla"
                            Click="OnCancelClick"
                            Background="{StaticResource MutedTextBrush}"/>

                    <Button Grid.Column="3"
                            Style="{StaticResource FooterButtonStyle}"
                            Content="Salva"
                            Click="OnSaveClick"
                            Background="{StaticResource ModalPrimaryActionBrush}"
                            FontWeight="Bold"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
