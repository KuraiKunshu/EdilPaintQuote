    <!-- Palette PDF: separata dalla UI ma modificabile dallo stesso file -->
    <Color x:Key="PdfWhiteColor">#FFFFFF</Color>
    <Color x:Key="PdfAccentRedColor">#EF5350</Color>
    <Color x:Key="PdfRedDarken2Color">#D32F2F</Color>
    <Color x:Key="PdfOrangeMediumColor">#FFA726</Color>
    <Color x:Key="PdfBlueDarken1Color">#1E88E5</Color>
    <Color x:Key="PdfGreenMediumColor">#66BB6A</Color>
    <Color x:Key="PdfGreenDarken1Color">#43A047</Color>
    <Color x:Key="PdfGreenDarken2Color">#388E3C</Color>
    <Color x:Key="PdfGreyLighten1Color">#E0E0E0</Color>
    <Color x:Key="PdfGreyLighten2Color">#EEEEEE</Color>
    <Color x:Key="PdfGreyLighten3Color">#F5F5F5</Color>
    <Color x:Key="PdfGreyMediumColor">#BDBDBD</Color>
