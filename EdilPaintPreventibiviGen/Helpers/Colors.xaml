    <SolidColorBrush x:Key="CostsPartnerBrush" Color="#E65100"/>
    <SolidColorBrush x:Key="CostsOurBrush" Color="#1565C0"/>
    <SolidColorBrush x:Key="CostsOurPressedBrush" Color="#0D47A1"/>
    <SolidColorBrush x:Key="CostsAdditionalBrush" Color="#6A1B9A"/>
    <SolidColorBrush x:Key="CostsGenerateBrush" Color="#FF6D00"/>

    <SolidColorBrush x:Key="NeutralButtonBackgroundBrush" Color="#FFF3F4F6"/>
    <SolidColorBrush x:Key="NeutralButtonBorderBrush" Color="#FFD1D5DB"/>
    <SolidColorBrush x:Key="NeutralButtonTextBrush" Color="#FF1F2937"/>
    <SolidColorBrush x:Key="NeutralButtonHoverBrush" Color="#FFE5E7EB"/>
    <SolidColorBrush x:Key="NeutralButtonHoverBorderBrush" Color="#FF9CA3AF"/>
    <SolidColorBrush x:Key="DangerSoftBackgroundBrush" Color="#FFFEE2E2"/>
    <SolidColorBrush x:Key="DangerSoftBorderBrush" Color="#FFFCA5A5"/>
    <SolidColorBrush x:Key="DangerSoftHoverBorderBrush" Color="#FFFECACA"/>
