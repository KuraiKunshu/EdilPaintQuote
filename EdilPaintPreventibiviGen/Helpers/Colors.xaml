<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette Colori Principale -->
    <Color x:Key="PrimaryBlueColor">#3498db</Color>
    <Color x:Key="SecondaryBlueColor">#2980b9</Color>
    <Color x:Key="DarkNavyColor">#2c3e50</Color>
    <Color x:Key="SuccessGreenColor">#27ae60</Color>
    <Color x:Key="DangerRedColor">#e74c3c</Color>
    <Color x:Key="PrimaryRedColor">#e74c3c</Color>
    <Color x:Key="PrimaryRedDarkColor">#c0392b</Color>
    <Color x:Key="PrimaryRedLightColor">#FFEBEE</Color>
    <Color x:Key="RedBorderColor">#FFCDD2</Color>
    <Color x:Key="Purple">#8b2dc7</Color>
    <Color x:Key="WarningYellowColor">#f1c40f</Color>
    <Color x:Key="AccentOrangeColor">#e67e22</Color>
    <Color x:Key="Black">Black</Color>
    
    <!-- Pennelli (Brushes) -->
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlueColor}"/>
    <SolidColorBrush x:Key="SecondaryBlueBrush" Color="{StaticResource SecondaryBlueColor}"/>
    <SolidColorBrush x:Key="DarkNavyBrush" Color="{StaticResource DarkNavyColor}"/>
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRedColor}"/>
    <SolidColorBrush x:Key="PrimaryRedBrush" Color="{StaticResource PrimaryRedColor}"/>
    <SolidColorBrush x:Key="PrimaryRedDarkBrush" Color="{StaticResource PrimaryRedDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryRedLightBrush" Color="{StaticResource PrimaryRedLightColor}"/>
    <SolidColorBrush x:Key="RedBorderBrush" Color="{StaticResource RedBorderColor}"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource Purple}"/>
    <SolidColorBrush x:Key="WarningYellowBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#F3F6FA"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FAFBFC"/>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="HoverSurfaceBrush" Color="#F8FAFC"/>

    <!-- Colori Testo -->
    <SolidColorBrush x:Key="DefaultTextBrush" Color="#2c3e50"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#7f8c8d"/>
    <SolidColorBrush x:Key="LightTextBrush" Color="#FFFFFF"/>

    <!-- Sfondi Liste e DataGrid -->
    <SolidColorBrush x:Key="RowBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#FFF9C4"/>
    <SolidColorBrush x:Key="GridLinesBrush" Color="#CCCCCC"/>

    <!-- Colori semantici UI: modifica questi per personalizzare i controlli principali -->
    <SolidColorBrush x:Key="MainHeaderBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MainHeaderBorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="ActionBarBackgroundBrush" Color="{StaticResource PrimaryRedDarkColor}"/>
    <SolidColorBrush x:Key="NewQuoteButtonBrush" Color="#f1c40f"/>
    <SolidColorBrush x:Key="GeneratePdfButtonBrush" Color="#27ae60"/>
    <SolidColorBrush x:Key="HistoryButtonBrush" Color="#2980b9"/>
    <SolidColorBrush x:Key="LaborListButtonBrush" Color="#3498db"/>
    <SolidColorBrush x:Key="LocalMaterialsButtonBrush" Color="#3498db"/>
    <SolidColorBrush x:Key="SettingsButtonBrush" Color="#7f8c8d"/>
    <SolidColorBrush x:Key="NewCustomerButtonBrush" Color="#3498db"/>
    <SolidColorBrush x:Key="SelectReferenceButtonBrush" Color="#2980b9"/>
    <SolidColorBrush x:Key="SelectCustomerButtonBrush" Color="#2c3e50"/>
    <SolidColorBrush x:Key="ModalPrimaryActionBrush" Color="#27ae60"/>
    <SolidColorBrush x:Key="SectionPanelBackgroundBrush" Color="#F6F8FA"/>

    <!-- Colori Stati Storico -->
    <SolidColorBrush x:Key="StatusFinalizzatoBrush" Color="#7cc2dc"/>
    <SolidColorBrush x:Key="StatusSpeditoBrush" Color="#fdf282"/>
    <SolidColorBrush x:Key="StatusConfermatoBrush" Color="#ddacf3"/>
    <SolidColorBrush x:Key="StatusFinitoBrush" Color="#b7f3ac"/>
    <SolidColorBrush x:Key="StatusRifiutatoBrush" Color="#f3acac"/>

    <!-- Colori condivisi: ogni valore usato dalle finestre XAML vive qui -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="GrayBrush" Color="Gray"/>
    <SolidColorBrush x:Key="NotificationRedBrush" Color="Red"/>
    <SolidColorBrush x:Key="SyncLocalOnlyBrush" Color="Red"/>
    <SolidColorBrush x:Key="SyncOnlineOnlyBrush" Color="Orange"/>
    <SolidColorBrush x:Key="SyncSyncedBrush" Color="LimeGreen"/>
    <SolidColorBrush x:Key="SyncUnknownBrush" Color="Gray"/>
    <SolidColorBrush x:Key="CustomerInvalidBorderBrush" Color="Red"/>
    <SolidColorBrush x:Key="CustomerValidBorderBrush" Color="Green"/>

    <SolidColorBrush x:Key="TextDark333Brush" Color="#333"/>
    <SolidColorBrush x:Key="CompactLabelBrush" Color="#555"/>
    <SolidColorBrush x:Key="ChevronBrush" Color="#666"/>
    <SolidColorBrush x:Key="PlaceholderTextBrush" Color="#999"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="ModalFieldBorderBrush" Color="#D0D7DE"/>
    <SolidColorBrush x:Key="InputButtonSurfaceBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="#E57373"/>
    <SolidColorBrush x:Key="MaterialRedBrush" Color="#D32F2F"/>
    <SolidColorBrush x:Key="SelectedTabBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="CompactBorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="LegacyLightBorderBrush" Color="#ddd"/>

