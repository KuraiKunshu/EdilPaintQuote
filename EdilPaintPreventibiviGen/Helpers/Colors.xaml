    <Color x:Key="PdfGreyDarken2Color">#616161</Color>
    <Color x:Key="PdfGreyDarken3Color">#424242</Color>

    <DropShadowEffect x:Key="ShadowEffect"
                      Color="{StaticResource Black}"
                      BlurRadius="18"
                      ShadowDepth="0"
                      Opacity="0.16"/>

</ResourceDictionary>
