<Window x:Class="EdilPaintPreventibiviGen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:EdilPaintPreventibiviGen.Helpers"
        mc:Ignorable="d"
        RenderOptions.BitmapScalingMode="HighQuality"
        Icon="Assets/Windowsicon/main.png"
        Title="Gestione Preventivi - EdilPaint"
        Height="900"
        Width="1250"
        Background="{StaticResource ShellBackgroundBrush}"
        MinWidth="1000"
        MinHeight="700"
        WindowState="Maximized"
        Closing="Window_Closing">

    <Window.Resources>
        <helpers:StringVisibilityConverter x:Key="StringToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="SoftRedComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#333"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FFEBEE"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FFCDD2"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="7"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="32"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1"
                                                        Background="#FAFAFA"
                                                        BorderBrush="#11000000"
                                                        BorderThickness="1,0,0,0"
                                                        CornerRadius="0,7,7,0"/>
                                                <Path Grid.Column="1"
                                                      Width="10" Height="6"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="#666"
                                                      Data="M 0 0 L 10 0 L 5 6 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#E57373"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#D32F2F"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Border" Property="Opacity" Value="0.6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,36,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="White"
                                            BorderBrush="#D9D9D9"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,4,0,0">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Popup" Property="MinHeight" Value="24"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource RowBackgroundBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="44"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="Foreground" Value="{StaticResource DefaultTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Border Margin="0,10,0,0"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"/>
                            <Border HorizontalAlignment="Left"
                                    Margin="12,0,0,0"
                                    Padding="8,2"
                                    Background="{StaticResource PanelBackgroundBrush}"
                                    CornerRadius="5">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.Foreground="{StaticResource DefaultTextBrush}"/>
                            </Border>
                            <ContentPresenter Margin="12,24,12,12"
                                              ContentSource="Content"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stile DataGrid compatto per il pannello collaborazione -->
        <Style x:Key="CostDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="MaxHeight" Value="130"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="RowHeight" Value="26"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="ColumnHeaderHeight" Value="22"/>
        </Style>

        <Style x:Key="CostDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="CostDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="15">

        <!-- ═══════════════════════════════════════ HEADER ═══════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource MainHeaderBackgroundBrush}"
                Effect="{DynamicResource ShadowEffect}"
                BorderBrush="{StaticResource MainHeaderBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18,12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Cliente principale -->
                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Preventivo n. " FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding QuoteNumber}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Visibility="{Binding SelectedCustomer, Converter={StaticResource StringToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedCustomer.DisplayName}"
                                       FontSize="14" FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource DarkNavyBrush}"/>
                            <Button Content="📁 Apri Cartella"
                                    Margin="10,0,0,0" Padding="5,2"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource GridLinesBrush}"
                                    BorderThickness="1" Cursor="Hand"
                                    Click="OnOpenCustomerFolderClick"/>
                            <Button Content="✏️ Modifica"
                                    Margin="6,0,0,0" Padding="5,2"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource GridLinesBrush}"
                                    BorderThickness="1" Cursor="Hand"
                                    Click="OnEditCustomerClick"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedCustomer.Address}" FontSize="12" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding SelectedCustomer.Email}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Cliente di riferimento -->
                <StackPanel Grid.Column="2" Margin="0,15,0,0"
                            Visibility="{Binding IsSecondCustomerEnabled, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="RIFERIMENTO:" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource SecondaryBlueBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedSecondCustomer.DisplayName}"
                                   FontSize="12" FontWeight="Bold"/>
                        <Button Content="📁 Apri Cartella"
                                Margin="10,0,0,0" Padding="5,2"
                                Background="Transparent"
                                BorderBrush="{StaticResource GridLinesBrush}"
                                BorderThickness="1" Cursor="Hand"
                                Click="OnOpenReferenceFolderClick"
                                Visibility="{Binding SelectedSecondCustomer, Converter={StaticResource StringToVis}}"/>
                        <Button Content="✏️ Modifica"
                                Margin="6,0,0,0" Padding="5,2"
                                Background="Transparent"
                                BorderBrush="{StaticResource GridLinesBrush}"
                                BorderThickness="1" Cursor="Hand"
                                Click="OnEditReferenceClick"
                                Visibility="{Binding SelectedSecondCustomer, Converter={StaticResource StringToVis}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedSecondCustomer.Address}" FontSize="12" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding SelectedSecondCustomer.Email}" FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>

                <!-- Selezione IVA -->
                <Border Grid.Column="3"
                        Background="White" Padding="8,4"
                        CornerRadius="6" BorderBrush="#E0E0E0"
                        BorderThickness="1" Margin="20,0"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="IVA" VerticalAlignment="Center"
                                   Margin="0,0,6,0" FontWeight="SemiBold" Foreground="#555"/>
                        <ComboBox Width="140"
                                  Style="{StaticResource SoftRedComboBox}"
                                  ItemsSource="{Binding IvaOptions}"
                                  SelectedItem="{Binding IvaType}"/>
                    </StackPanel>
                </Border>

                <!-- Selezione Logo -->
                <Border Grid.Column="4"
                        Background="White" Padding="8,4"
                        CornerRadius="6" BorderBrush="#E0E0E0"
                        BorderThickness="1" Margin="10,0,0,0"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Logo" VerticalAlignment="Center"
                                   Margin="0,0,6,0" FontWeight="SemiBold" Foreground="#555"/>
                        <ComboBox Width="140"
                                  Style="{StaticResource SoftRedComboBox}"
                                  ItemsSource="{Binding Logos}"
                                  SelectedItem="{Binding SelectedLogo}"/>
                    </StackPanel>
                </Border>

                <!-- Pulsanti azione header -->
                <StackPanel Grid.Column="5" Orientation="Vertical" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                        <CheckBox Content="riferimento"
                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                  IsChecked="{Binding IsSecondCustomerEnabled}"/>
                        <CheckBox Content="🤝 collaborazione"
                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                  IsChecked="{Binding IsJointVenture}"/>
                        <Button Content="NUOVO CLIENTE"
                                Width="110" Height="30"
                                Background="{StaticResource NewCustomerButtonBrush}"
                                Foreground="White" BorderThickness="0"
                                Click="OnNewCustomerClick"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="SEL. RIFERIMENTO"
                                Width="110" Height="30" Margin="0,0,5,0"
                                Background="{StaticResource SelectReferenceButtonBrush}"
                                Foreground="White" BorderThickness="0"
                                Click="OnSelectReferenceClick"
                                Visibility="{Binding IsSecondCustomerEnabled, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="SEL. CLIENTE"
                                Width="110" Height="30"
                                Background="{StaticResource SelectCustomerButtonBrush}"
                                Foreground="White" BorderThickness="0"
                                Click="OnSelectCustomerClick"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════ PANNELLO COLLABORAZIONE ═══════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Visibility="{Binding IsJointVenture, Converter={StaticResource BoolToVis}}"
                Background="#FFFFFBEB"
                BorderBrush="#FFF6C453"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,10"
                Margin="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="175"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Nome ditta partner -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top">
                    <TextBlock Text="🤝 Ditta Partner"
                               FontWeight="Bold" FontSize="11"
                               Foreground="#E65100" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PartnerCompanyName, UpdateSourceTrigger=PropertyChanged}"
                             Height="28" Padding="6,0"
                             VerticalContentAlignment="Center"
                             FontSize="12"/>
                    <TextBlock Text="Inserisci il nome della ditta collaboratrice"
                               FontSize="9" Foreground="#999" Margin="0,3,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Nostri Costi -->
                <GroupBox Grid.Column="1" Margin="0,0,5,0" Padding="5,2">
                    <GroupBox.Header>
                        <TextBlock Text="🏢 Nostri Costi"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="#1565C0"/>
                    </GroupBox.Header>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Bottom"
                                Content="+ Aggiungi voce"
                                Height="22" FontSize="11"
                                Margin="0,3,0,0"
                                Background="#1565C0" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="OnAddOurCostClick"/>
                        <DataGrid x:Name="GridOurCosts"
                                  ItemsSource="{Binding OurCosts}"
                                  Style="{StaticResource CostDataGridStyle}"
                                  RowStyle="{StaticResource CostDataGridRowStyle}"
                                  CellStyle="{StaticResource CostDataGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Descrizione"
                                                    Binding="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="€"
                                                    Binding="{Binding Amount, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                                                    Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="26">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" FontSize="10"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource DangerRedBrush}"
                                                    Cursor="Hand"
                                                    Click="OnDeleteCostRowClick"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>

                <!-- Costi Partner -->
                <GroupBox Grid.Column="2" Margin="0,0,5,0" Padding="5,2">
                    <GroupBox.Header>
                        <TextBlock Text="🤝 Costi Partner"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="#E65100"/>
                    </GroupBox.Header>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Bottom"
                                Content="+ Aggiungi voce"
                                Height="22" FontSize="11"
                                Margin="0,3,0,0"
                                Background="#E65100" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="OnAddPartnerCostClick"/>
                        <DataGrid x:Name="GridPartnerCosts"
                                  ItemsSource="{Binding PartnerCosts}"
                                  Style="{StaticResource CostDataGridStyle}"
                                  RowStyle="{StaticResource CostDataGridRowStyle}"
                                  CellStyle="{StaticResource CostDataGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Descrizione"
                                                    Binding="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="€"
                                                    Binding="{Binding Amount, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                                                    Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="26">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" FontSize="10"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource DangerRedBrush}"
                                                    Cursor="Hand"
                                                    Click="OnDeleteCostRowClick"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>

                <!-- Costi Aggiuntivi -->
                <GroupBox Grid.Column="3" Padding="5,2">
                    <GroupBox.Header>
                        <TextBlock Text="➕ Costi Aggiuntivi"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="#6A1B9A"/>
                    </GroupBox.Header>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Bottom"
                                Content="+ Aggiungi voce"
                                Height="22" FontSize="11"
                                Margin="0,3,0,0"
                                Background="#6A1B9A" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="OnAddAdditionalCostClick"/>
                        <DataGrid x:Name="GridAdditionalCosts"
                                  ItemsSource="{Binding AdditionalCosts}"
                                  Style="{StaticResource CostDataGridStyle}"
                                  RowStyle="{StaticResource CostDataGridRowStyle}"
                                  CellStyle="{StaticResource CostDataGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Descrizione"
                                                    Binding="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="€"
                                                    Binding="{Binding Amount, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                                                    Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="26">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" FontSize="10"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource DangerRedBrush}"
                                                    Cursor="Hand"
                                                    Click="OnDeleteCostRowClick"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>

                <!-- Pulsante PDF Costi -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="10,0,0,0" Width="115">
                    <Button Content="📄 PDF Costi"
                            Height="36"
                            Background="#FF6D00" Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold" FontSize="12"
                            Cursor="Hand"
                            ToolTip="Genera PDF interno con la ripartizione dei costi"
                            Click="OnGenerateCostsPdfClick"/>
                    <TextBlock Text="uso interno"
                               FontSize="9" Foreground="#999"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ FOOTER ═══════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource ActionBarBackgroundBrush}"
                BorderThickness="0"
                CornerRadius="10"
                Padding="16,12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Pulsanti azione principali -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Nuovo"
                            Width="100" Height="35" Margin="0,0,8,0"
                            Background="{StaticResource NewQuoteButtonBrush}"
                            Foreground="White" BorderThickness="0"
                            Click="OnNewQuoteClick"/>
                    <Button Content="Genera PDF"
                            Width="120" Height="35" Margin="0,0,8,0"
                            Background="{StaticResource GeneratePdfButtonBrush}"
                            Foreground="White" BorderThickness="0"
                            FontWeight="Bold"
                            Click="OnGeneratePdfClick"/>
                    <Button Content="Storico"
                            Width="110" Height="35" Margin="0,0,8,0"
                            Background="{StaticResource HistoryButtonBrush}"
                            Foreground="White" BorderThickness="0"
                            Click="OnOpenHistoryClick"/>
                    <Button Content="Lista Lavori"
                            Width="120" Height="35"
                            Background="{StaticResource LaborListButtonBrush}"
                            Foreground="White" BorderThickness="0"
                            Click="OnOpenLaborListClick"/>
                    <Button Content="Materiali Locali"
                            Width="130" Height="35" Margin="8,0,0,0"
                            Background="{StaticResource LocalMaterialsButtonBrush}"
                            Foreground="White" BorderThickness="0"
                            Click="OnOpenMaterialListClick"/>
                </StackPanel>

                <!-- Sconti -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="Sconto Mat. %"
                                   FontSize="10" HorizontalAlignment="Center"
                                   Foreground="{StaticResource LightTextBrush}"/>
                        <TextBox Width="58" Height="28"
                                 TextAlignment="Center"
                                 Text="{Binding MaterialDiscount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Sconto Lav. %"
                                   FontSize="10" HorizontalAlignment="Center"
                                   Foreground="{StaticResource LightTextBrush}"/>
                        <TextBox Width="58" Height="28"
                                 TextAlignment="Center"
                                 Text="{Binding LaborDiscount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Totali -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Imponibile:"
                                   Foreground="{StaticResource LightTextBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Imponibile, StringFormat='€ {0:N2}'}"
                                   HorizontalAlignment="Right" FontSize="12"
                                   Foreground="{StaticResource LightTextBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="IVA:"
                                   Foreground="{StaticResource LightTextBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding IvaTotale, StringFormat='€ {0:N2}'}"
                                   HorizontalAlignment="Right" FontSize="12"
                                   Foreground="{StaticResource LightTextBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="TOTALE"
                                   FontWeight="Bold" FontSize="18"
                                   Foreground="{StaticResource LightTextBrush}"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding TotaleGenerale, StringFormat='€ {0:N2}'}"
                                   FontWeight="Bold" FontSize="18"
                                   Foreground="{StaticResource WarningYellowBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ CORPO ═══════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- Colonna sinistra: catalogo + voci + tabelle -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Catalogo -->
                <GroupBox Header="Catalogo" Grid.Row="0" Margin="0,10,0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="Materiali"/>
                            <ComboBox IsEditable="True" IsTextSearchEnabled="False"
                                      ItemsSource="{Binding AllCatalogMaterials}"
                                      DisplayMemberPath="Label"
                                      SelectedItem="{Binding SelectedCatalogMaterial}"
                                      TextBoxBase.TextChanged="OnMaterialSearchChanged"
                                      DropDownOpened="OnComboDropDownOpened"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <TextBlock Text="Lavorazioni"/>
                            <ComboBox IsEditable="True" IsTextSearchEnabled="False"
                                      ItemsSource="{Binding FilteredLabors}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedCatalogLabor}"
                                      TextBoxBase.TextChanged="OnLaborSearchChanged"
                                      DropDownOpened="OnComboDropDownOpened"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Nuova Voce -->
                <GroupBox Header="Nuova Voce" Grid.Row="1" Margin="0,5">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Voce:" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Margin="0,0,10,5"
                                 Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="Valore (€):" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox Grid.Row="0" Grid.Column="3"
                                 Margin="0,0,10,5"
                                 Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Descrizione:" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Margin="0,0,10,5"
                                 Text="{Binding InputDescription, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="60"
                                 VerticalContentAlignment="Top"/>
                        <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="Quantità:" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox Grid.Row="1" Grid.Column="3"
                                 Margin="0,0,10,5" VerticalAlignment="Center"
                                 Text="{Binding InputQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Grid.Row="1" Grid.Column="4"
                                  Content="Bene significativo"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding IsSignificant}"/>

                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                                    Orientation="Horizontal" HorizontalAlignment="Right"
                                    Margin="0,5,0,0">
                            <Button Content="Aggiungi a MATERIALI"
                                    Padding="15,5" Margin="0,0,10,0"
                                    Background="{StaticResource DarkNavyBrush}"
                                    Foreground="White" BorderThickness="0"
                                    Click="OnAddMaterialClick"/>
                            <Button Content="Aggiungi a LAVORI"
                                    Padding="15,5"
                                    Background="{StaticResource SecondaryBlueBrush}"
                                    Foreground="White" BorderThickness="0"
                                    Click="OnAddLaborClick"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Tabelle Materiali e Lavorazioni -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Materiali -->
                    <GroupBox Grid.Column="0" Header="Materiali" Margin="0,5,5,5">
                        <DataGrid ItemsSource="{Binding Materials}"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="DataGrid_PreviewMouseMove"
                                  Drop="DataGrid_Drop"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Vertical"
                                  VerticalGridLinesBrush="{StaticResource GridLinesBrush}"
                                  RowHeight="50"
                                  Background="White"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource GridLinesBrush}"
                                  AlternationCount="2"
                                  CanUserReorderColumns="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="⋮⋮"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="14" Cursor="SizeAll"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✏️" Background="Transparent"
                                                    BorderThickness="0" Click="OnEditRowClick"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Descrizione Voce" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5,4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold" FontSize="12"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap"
                                                           Margin="0,2,0,0"
                                                           Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="BS" Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSignificant, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Q.tà" Binding="{Binding Quantity}" Width="50"/>
                                <DataGridTextColumn Header="Sc. %" Binding="{Binding Discount}" Width="50"/>
                                <DataGridTextColumn Header="Prezzo unit." Binding="{Binding UnitPrice, StringFormat=N2}" Width="100"/>
                                <DataGridTextColumn Header="Totale" Binding="{Binding TotalPrice, StringFormat=N2}" IsReadOnly="True" Width="100"/>
                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" Background="Transparent"
                                                    BorderThickness="0" Click="OnDeleteRowClick"
                                                    Foreground="{StaticResource DangerRedBrush}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <!-- Lavorazioni -->
                    <GroupBox Grid.Column="1" Header="Lavorazioni" Margin="5,5,0,5">
                        <DataGrid ItemsSource="{Binding Labors}"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="DataGrid_PreviewMouseMove"
                                  Drop="DataGrid_Drop"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Vertical"
                                  VerticalGridLinesBrush="{StaticResource GridLinesBrush}"
                                  RowHeight="50"
                                  Background="White"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource GridLinesBrush}"
                                  AlternationCount="2"
                                  CanUserReorderColumns="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="⋮⋮"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="14" Cursor="SizeAll"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✏️" Background="Transparent"
                                                    BorderThickness="0" Click="OnEditRowClick"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Descrizione Lavorazione" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5,4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold" FontSize="12"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap"
                                                           Margin="0,2,0,0"
                                                           Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="BS" Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSignificant, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Q.tà" Binding="{Binding Quantity}" Width="50"/>
                                <DataGridTextColumn Header="Sc. %" Binding="{Binding Discount}" Width="50"/>
                                <DataGridTextColumn Header="Prezzo unit." Binding="{Binding UnitPrice, StringFormat=N2}" Width="100"/>
                                <DataGridTextColumn Header="Totale" Binding="{Binding TotalPrice, StringFormat=N2}" IsReadOnly="True" Width="100"/>
                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" Background="Transparent"
                                                    BorderThickness="0" Click="OnDeleteRowClick"
                                                    Foreground="{StaticResource DangerRedBrush}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </Grid>

            <!-- Colonna destra: Allegati e Note -->
            <Grid Grid.Column="1" Margin="10,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Foto / Allegati">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Aggiungi"
                                    Width="110" Height="30" Margin="0,0,5,0"
                                    Background="{StaticResource MutedTextBrush}"
                                    Foreground="White" BorderThickness="0"
                                    Click="OnAddImageClick"/>
                            <Button Content="Rimuovi"
                                    Width="110" Height="30"
                                    Background="{StaticResource DangerRedBrush}"
                                    Foreground="White" BorderThickness="0"
                                    Click="OnRemoveImageClick"/>
                        </StackPanel>
                        <ListBox x:Name="LstImages"
                                 Background="White" BorderBrush="#ddd"
                                 ItemsSource="{Binding AttachedImages}"
                                 AllowDrop="True"
                                 Drop="OnImageDrop"
                                 PreviewKeyDown="OnImagePaste">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource StringToVis}, ConverterParameter='FileName'}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Termini di pagamento / Note" Margin="0,10,0,0">
                    <TextBox TextWrapping="Wrap" AcceptsReturn="True"
                             Text="{Binding PaymentTerms, UpdateSourceTrigger=PropertyChanged}"/>
                </GroupBox>
            </Grid>
        </Grid>

    </DockPanel>
</Window>
